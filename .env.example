# ══════════════════════════════════════════════════════════════
# Versato Backend — Variables de Entorno
# Copia como .env para desarrollo local.
# En producción (Render), configura estas variables en el dashboard.
# NUNCA subas el .env real al repositorio.
# ══════════════════════════════════════════════════════════════

# Servidor
PORT=3000
NODE_ENV=development   # Cambia a "production" en Render

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=tu_token_permanente_de_meta
PHONE_NUMBER_ID=tu_phone_number_id
VERIFY_TOKEN=tu_verify_token_personalizado
APP_SECRET=tu_app_secret_de_meta   # En Meta: App → Configuración → Básica → Clave secreta

# Base de datos (Supabase)
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Autenticación
JWT_SECRET=usa_una_cadena_larga_y_aleatoria_aqui

# CORS — URL del frontend en producción (opcional, fallback a los valores por defecto)
FRONTEND_URL=https://app.versato.com.pe

# Alertas — intervalo en ms para revisar conversaciones estancadas (default: 5 min)
ALERT_CHECK_INTERVAL_MS=300000

# Backups Automáticos
BACKUP_ENABLED=false
BACKUP_DIRECTORY=backups
BACKUP_RETENTION_DAYS=7

